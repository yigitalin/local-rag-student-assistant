{
  "name": "oil-refinery-local-rag",
  "version": "2.0.0",
  "description": "Offline RAG-powered technical support assistant for oil refinery inspection, maintenance, and troubleshooting using Foundry Local",
  "type": "module",
  "scripts": {
    "ingest": "node src/ingest.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0",
    "foundry-local-sdk": "^0.9.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leestott/local-rag.git"
  },
  "keywords": [
    "rag",
    "offline-ai",
    "foundry-local",
    "phi-3",
    "oil-refinery",
    "technical-support",
    "maintenance",
    "sqlite",
    "tfidf"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "foundry-local-sdk@0.9.0": true,
    "koffi@2.16.2": true
  }
}
